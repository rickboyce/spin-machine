{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Spin Machine dev server",
      "type": "shell",
      "command": "node",
      "args": [
        "dev/server.js"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Spin Machine dev server running",
          "endsPattern": "Serving "
        }
      },
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      }
    }
  ]
}
